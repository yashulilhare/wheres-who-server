// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  username    String       @unique
  password    String
  records     Record[]
  activeGames ActiveGame[]
}

model Mode {
  id   Int    @id @default(autoincrement())
  name String @unique

  // size of image used for each mode (in pixel)
  xLength Int
  yLength Int

  records     Record[]
  characters  Character[]
  activeGames ActiveGame[]

  @@index([name])
}

model Record {
  id        String   @id @default(cuid())
  duration  Int
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  modeId Int
  mode   Mode @relation(fields: [modeId], references: [id], onDelete: Cascade)

  @@index([modeId, duration, createdAt])
}

model Character {
  id   String @id @default(cuid())
  name String

  // imageCode is number-code for character-image stored with the same name on hosting provider, ex. 1.png ~ imageCode = 1
  imageCode Int

  // 
  xposition Float
  yposition Float

  modeId Int
  mode   Mode @relation(fields: [modeId], references: [id], onDelete: Cascade)
}

model ActiveGame {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  modeId Int
  mode   Mode @relation(fields: [modeId], references: [id], onDelete: Cascade)

  characterData   Json
  innocentKills   Int
  lastTimerScore  Int
  charactersFound Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt()

  @@index([userId])
}
